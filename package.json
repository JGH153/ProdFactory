{
	"name": "prodfactory",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3001",
		"dev:db": "docker compose up",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"biome:migrate": "biome migrate --write",
		"typecheck": "tsc --noEmit",
		"knip": "knip",
		"test": "vitest run",
		"test:ui": "vitest run .test.tsx",
		"test:logic": "vitest run --exclude 'src/**/*.test.tsx'",
		"test:watch": "vitest",
		"validate": "pnpm test && biome check . && tsc --noEmit && knip && pnpm build",
		"update-deps": "pnpm dlx npm-check-updates -i -p pnpm",
		"update-deps-minor": "pnpm dlx npm-check-updates -i -p pnpm --target minor"
	},
	"dependencies": {
		"@hugeicons/core-free-icons": "^3.3.0",
		"@hugeicons/react": "^1.1.5",
		"@tanstack/react-query": "^5.90.21",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"ioredis": "^5.10.0",
		"logrocket": "^12.0.0",
		"motion": "^12.34.3",
		"next": "^16.1.6",
		"pino": "^10.3.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@tailwindcss/postcss": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.13",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"axe-core": "^4.11.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"happy-dom": "^20.7.0",
		"jsdom": "^28.1.0",
		"knip": "^5.85.0",
		"msw": "^2.12.10",
		"pino-pretty": "^13.1.3",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"vitest-fail-on-console": "^0.10.1"
	}
}
