# ============================================
# Redis Configuration
# ============================================

# Local Development (Docker Compose)
REDIS_URL=redis://localhost:6380

# Production (Upstash - set in Vercel dashboard)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ============================================
# Logging (pino)
# ============================================

# Log level for local development: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Log level for unit tests (vitest): defaults to silent if unset
TEST_LOG_LEVEL=silent

# Hide the JSON object in pino-pretty output (dev only): true | false (default: true)
LOG_HIDE_OBJECT=true
